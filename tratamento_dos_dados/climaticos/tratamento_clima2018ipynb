ia/dengue2018_tratado.csv')\n","\n","#transformando os valores em inteiro para que o cruzamento das bases não dê bronca\n","df_dengue['SEMANA EPDM'] = pd.to_numeric(df_dengue['SEMANA EPDM'], errors='coerce')\n","\n","#criando uma coluna para agregar os casos em quantidade por semana\n","df_casos_semanal = df_dengue.groupby('SEMANA EPDM').size().reset_index(name='TOTAL_CASOS')\n","df_casos_semanal = df_casos_semanal.rename(columns={'SEMANA EPDM': 'SEMANA'})\n","\n","\n","\n","#fazendo o merge propriamente dito, utilizando o inner, serve pra utilizar apenas colunas que estão presente nas duas tabelas\n","df_final = pd.merge(df_clima_semanal, df_casos_semanal, on='SEMANA', how='inner')\n","\n","#salvandotratamento_clima2025.\n","#df_final.to_csv('dataset_clima/semana_epdm.csv', index=False)\n","\n","df_final.head(10)"]},{"cell_type":"code","source":["df= pd.read_csv('/content/drive/MyDrive/Pivic/dados/Dados/Institudo de Metereologia/dados 2018/INMET_NE_PB_A313_CAMPINA GRANDE_01-01-2018_A_31-12-2018.CSV',sep=';',\n","                       decimal=',',\n","                       skiprows=8,\n","                       encoding='latin1')\n","df.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":331},"id":"RjjX3uuv9bv-","executionInfo":{"status":"ok","timestamp":1770666739229,"user_tz":180,"elapsed":165,"user":{"displayName":"caio","userId":"00142445668749718611"}},"outputId":"2d3651a3-82e5-4f89-b569-5a34c3714d58"},"execution_count":4,"outputs":[{"output_type":"execute_result","data":{"text/plain":["  DATA (YYYY-MM-DD) HORA (UTC)  PRECIPITAÇÃO TOTAL, HORÁRIO (mm)  \\\n","0        2018-01-01      00:00                               0.0   \n","1        2018-01-01      01:00                               0.0   \n","2        2018-01-01      02:00                               0.0   \n","3        2018-01-01      03:00                               0.0   \n","4        2018-01-01      04:00                               0.0   \n","\n","   PRESSAO ATMOSFER